# Zendesk Configuration (required)
ZENDESK_SUBDOMAIN=your-company

# Authentication Method 1: OAuth Bearer Token (preferred for integrations)
# Use this if you have an OAuth access token
#ZENDESK_OAUTH_TOKEN=your-oauth-access-token

# Authentication Method 2: API Token (Basic Auth)
# Use this if you have email + API token
ZENDESK_EMAIL=your-email@company.com
ZENDESK_API_TOKEN=your-api-token

# Note: Use either ZENDESK_OAUTH_TOKEN OR (ZENDESK_EMAIL + ZENDESK_API_TOKEN)
# If both are set, OAuth token takes precedence

# Application Configuration
PORT=3000
SCRAPE_INTERVAL_SECONDS=60
LOG_LEVEL=info

# Mock Mode (set to true for testing without real Zendesk API)
ZENDESK_MOCK=false