# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is in .gitignore — your credentials stay local.

# --- Zendesk ---
ZENDESK_SUBDOMAIN=your-company
# ZENDESK_MOCK=true  # uncomment to test without API access

# Auth option 1: OAuth (recommended)
#ZENDESK_OAUTH_TOKEN=your-oauth-token

# Auth option 2: API token
ZENDESK_EMAIL=agent@company.com
ZENDESK_API_TOKEN=your-api-token

# --- App ---
PORT=9091
SCRAPE_INTERVAL_SECONDS=300
LOG_LEVEL=info
