# Zendesk Configuration
ZENDESK_SUBDOMAIN=your-company

# --- Authentication (choose one) ---

# Option 1: OAuth Bearer Token (recommended)
#ZENDESK_OAUTH_TOKEN=your-oauth-token

# Option 2: API Token (Basic Auth)
ZENDESK_EMAIL=agent@company.com
ZENDESK_API_TOKEN=your-api-token

# If both are set, OAuth takes precedence.

# --- App Configuration ---
PORT=9091
SCRAPE_INTERVAL_SECONDS=300
LOG_LEVEL=info

# Mock mode (no API calls, fake data for testing)
ZENDESK_MOCK=false
